<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BookFinder Pro | OLIPT1</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* REINFORCED STICKY LOGIC */
        html {
            scroll-behavior: smooth;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: #0f172a;
            color: #cbd5e1;
            overflow-x: hidden;
        }

        /* Modern Glassmorphism Utilities */
        .glass-panel {
            background: rgba(15, 23, 42, 0.8); 
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        /* Permanent Sticky Navigation */
        .sticky-nav {
            position: -webkit-sticky;
            position: sticky;
            top: 0;
            width: 100%;
            z-index: 1000;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }

        .glass-card:hover {
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(255, 255, 255, 0.3);
            transform: translateY(-5px);
        }

        #suggestions-box {
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(20px);
            z-index: 9999 !important;
        }

        .bg-blob {
            position: fixed;
            width: 500px;
            height: 500px;
            filter: blur(80px);
            z-index: -1;
            border-radius: 50%;
            opacity: 0.3;
        }
    </style>
</head>
<body class="antialiased">

    <div class="bg-blob bg-indigo-600 top-[-100px] left-[-100px] animate-pulse"></div>
    <div class="bg-blob bg-purple-600 bottom-[-100px] right-[-100px] animate-bounce" style="animation-duration: 15s;"></div>

    <nav class="sticky-nav glass-panel py-4 px-6">
        <div class="container mx-auto flex justify-between items-center">
            <a href="/" class="text-2xl font-black bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent flex items-center gap-2">
                <span>📚</span> BookFinder
            </a>
            <div class="flex items-center gap-4">
                <a href="/docs" class="text-[10px] font-bold text-indigo-400 hover:text-white uppercase tracking-widest border border-indigo-500/30 hover:border-indigo-400 px-4 py-2 rounded-full transition-all duration-300 hover:shadow-[0_0_15px_rgba(129,140,248,0.5)] bg-indigo-500/5">
                    View Documentation
                </a>
            </div>
        </div>
    </nav>

    <main class="container mx-auto px-4 py-12">
        
        <section class="max-w-3xl mx-auto mb-16 relative">
            <div class="glass-card rounded-3xl p-8 md:p-12 shadow-2xl">
                <h2 class="text-3xl font-extrabold text-center mb-8 text-white tracking-tight text-balance">Discover your next favorite story.</h2>
                <form action="/search" method="POST" class="flex flex-col sm:flex-row gap-4 relative">
                    <div class="relative flex-grow">
                        <input type="text" id="live-search" name="book_name" autocomplete="off"
                            placeholder="Title, Author, or ISBN..." 
                            class="w-full bg-slate-900/50 border border-slate-700 px-6 py-4 rounded-2xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-white placeholder-slate-500 transition-all">
                        
                        <div id="suggestions-box" class="absolute left-0 right-0 mt-3 border border-white/10 rounded-2xl shadow-2xl hidden max-h-80 overflow-y-auto overflow-x-hidden"></div>
                    </div>
                    <button type="submit" class="bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 text-white font-bold px-10 py-4 rounded-2xl shadow-lg shadow-indigo-500/20 transition-all active:scale-95">
                        SEARCH
                    </button>
                </form>
            </div>
        </section>

        <% if (typeof isHomePage !== 'undefined' && isHomePage && typeof genreData !== 'undefined') { %>
            <% Object.keys(genreData).forEach(genre => { %>
                <section class="mb-20">
                    <div class="flex items-center gap-6 mb-10">
                        <h2 class="text-2xl font-black text-white uppercase tracking-tighter"><%= genre %></h2>
                        <div class="h-[1px] flex-grow bg-gradient-to-r from-indigo-500/50 to-transparent"></div>
                        <form action="/search" method="POST">
                            <input type="hidden" name="book_name" value="subject:<%= genre %>">
                            <button type="submit" class="text-xs font-bold text-indigo-400 hover:text-indigo-300 tracking-widest uppercase">Explore All</button>
                        </form>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                        <% genreData[genre].forEach(book => { %>
                            <div class="glass-card rounded-3xl overflow-hidden flex flex-col group p-2">
                                <div class="h-64 bg-slate-900/40 rounded-2xl flex items-center justify-center p-6 mb-4 relative overflow-hidden">
                                    <% if (book.volumeInfo.imageLinks) { %>
                                        <img src="<%= book.volumeInfo.imageLinks.thumbnail %>" class="h-full object-contain shadow-2xl group-hover:rotate-3 group-hover:scale-110 transition-transform duration-500">
                                    <% } else { %>
                                        <div class="text-slate-600 text-4xl">📖</div>
                                    <% } %>
                                </div>
                                <div class="px-4 pb-4 flex-grow flex flex-col text-center">
                                    <h3 class="font-bold text-white text-md leading-snug line-clamp-2 h-12 mb-1"><%= book.volumeInfo.title %></h3>
                                    <p class="text-xs text-slate-400 font-medium mb-4 truncate"><%= book.volumeInfo.authors ? book.volumeInfo.authors[0] : 'Unknown' %></p>
                                    <a href="<%= book.volumeInfo.infoLink %>" target="_blank" class="mt-auto block text-center py-3 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-[10px] font-black tracking-widest text-indigo-400 uppercase transition-all">
                                        View Details
                                    </a>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </section>
            <% }); %>

        <% } else if (typeof books !== 'undefined' && books && books.length > 0) { %>
            <div class="flex items-center justify-between mb-12 border-b border-white/10 pb-6">
                <h2 class="text-3xl font-black text-white">Search Results</h2>
                <a href="/" class="px-6 py-2 glass-card rounded-full text-xs font-bold text-indigo-400 hover:bg-white/10 transition-all">← Back to Discovery</a>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-10">
                <% books.forEach(book => { %>
                    <div class="glass-card rounded-3xl p-3 flex flex-col group">
                        <div class="h-72 bg-slate-900/40 rounded-2xl flex items-center justify-center p-8 mb-6">
                            <% if (book.volumeInfo.imageLinks) { %>
                                <img src="<%= book.volumeInfo.imageLinks.thumbnail %>" class="h-full object-contain shadow-2xl group-hover:scale-105 transition-transform duration-500">
                            <% } %>
                        </div>
                        <div class="px-2 pb-2">
                            <h3 class="font-bold text-white text-lg leading-tight mb-2 line-clamp-1"><%= book.volumeInfo.title %></h3>
                            <p class="text-sm text-slate-400 mb-6 font-medium"><%= book.volumeInfo.authors ? book.volumeInfo.authors.join(', ') : 'Unknown Author' %></p>
                            <a href="<%= book.volumeInfo.infoLink %>" target="_blank" class="block text-center py-4 rounded-2xl bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-bold text-xs tracking-widest uppercase hover:shadow-indigo-500/40 transition-all">
                                DETAILS
                            </a>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="max-w-2xl mx-auto mb-8 bg-amber-500/10 border-l-4 border-amber-500 p-4 rounded text-amber-200 shadow-sm text-center">
                <p class="font-medium text-sm">Notice: <%= error %></p>
            </div>
        <% } %>
    </main>

    <footer class="mt-20 border-t border-white/10 py-16 text-center relative overflow-hidden bg-slate-900/50">
        <div class="container mx-auto px-4">
            <p class="text-slate-400 text-sm mb-2 font-medium">Project Developed by</p>
            <p class="text-2xl font-black text-white">Joseph Amandy</p>
            <div class="mt-4 inline-block px-4 py-1 glass-card rounded-full text-[10px] font-bold text-slate-500 uppercase tracking-[0.3em]">
                OLIPT1 Integrative Programming
            </div>
        </div>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('live-search');
            const suggestionsBox = document.getElementById('suggestions-box');
            let timeout = null;

            searchInput.addEventListener('input', () => {
                clearTimeout(timeout);
                const query = searchInput.value.trim();

                if (query.length < 3) {
                    suggestionsBox.classList.add('hidden');
                    return;
                }

                timeout = setTimeout(async () => {
                    try {
                        const res = await fetch(`/api/suggestions?q=${encodeURIComponent(query)}`);
                        const data = await res.json();
                        if (data && data.length > 0) {
                            suggestionsBox.innerHTML = data.map(book => `
                                <a href="${book.link}" target="_blank" class="block px-6 py-4 hover:bg-white/5 border-b border-white/5 last:border-0 transition-all">
                                    <p class="text-sm font-bold text-white truncate">${book.title}</p>
                                    <p class="text-[10px] text-slate-500 uppercase font-black mt-1">${book.author}</p>
                                </a>
                            `).join('');
                            suggestionsBox.classList.remove('hidden');
                        }
                    } catch (err) { console.error(err); }
                }, 300);
            });

            document.addEventListener('click', (e) => {
                if (!searchInput.contains(e.target)) suggestionsBox.classList.add('hidden');
            });
        });
    </script>
</body>
</html>